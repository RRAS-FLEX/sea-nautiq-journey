VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GTM_ID=GTM-XXXXXXX
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_your_payment_link_here

# Supabase (optional, for production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Tailscale — set to your machine's Tailscale hostname for remote HMR support
# Find it in: Tailscale app > this machine's name (e.g. my-laptop.tail1234.ts.net)
# Leave blank when developing locally without Tailscale
VITE_TAILSCALE_HOST=

